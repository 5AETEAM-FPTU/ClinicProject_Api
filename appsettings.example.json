{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "Clinic": {
      "ConnectionString": "Server=clinic-mysql;Port=3306;Database=ClinicDb;User=root;Password=ClinicDb@2024;Allow User Variables=true;",
      "CommandTimeOut": 30,
      "EnableRetryOnFailure": 3,
      "EnableSensitiveDataLogging": false,
      "EnableDetailedErrors": false,
      "EnableThreadSafetyChecks": true,
      "EnableServiceProviderCaching": true
    }
  },

  "Cache": {
    "Redis": {
      "ConnectionString": "clinic-redis:6379"
    }
  },

  "SmtpServer": {
    "GoogleGmail": {
      "Mail": "your-email@gmail.com",
      "DisplayName": "Clinic System",
      "Password": "your-google-app-password",
      "Host": "smtp.gmail.com",
      "Port": 587,
      "WebUrl": "https://your-domain.com"
    }
  },

  "AspNetCoreIdentity": {
    "Password": {
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": true,
      "RequiredLength": 8,
      "RequiredUniqueChars": 1
    },
    "Lockout": {
      "DefaultLockoutTimeSpanInSecond": 300,
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": true
    },
    "User": {
      "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._@+",
      "RequireUniqueEmail": true
    },
    "SignIn": {
      "RequireConfirmedEmail": false,
      "RequireConfirmedPhoneNumber": false
    }
  },

  "Authentication": {
    "Jwt": {
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ValidateIssuerSigningKey": true,
      "RequireExpirationTime": true,
      "ValidIssuer": "https://your-domain.com",
      "ValidAudience": "https://your-domain.com",
      "IssuerSigningKey": "your-super-secret-jwt-key-at-least-32-characters-long!!",
      "ValidTypes": ["at+jwt"]
    }
  },

  "VNPay": {
    "SecretKey": "your-vnpay-secret-key"
  },

  "Stringee": {
    "ProjectId": "your-stringee-project-id",
    "SecretKey": "your-stringee-secret-key",
    "SID": "your-stringee-sid",
    "Cty": "stringee"
  },

  "BaseEndpointUrl": {
    "Api": "https://your-domain.com",
    "Client": "https://your-client-domain.com",
    "Admin": "https://your-admin-domain.com"
  },

  "ApiRateLimiter": {
    "FixedWindow": {
      "RemoteIpAddress": {
        "PermitLimit": 100,
        "QueueProcessingOrder": 0,
        "QueueLimit": 10,
        "Window": 60,
        "AutoReplenishment": true
      }
    }
  },

  "Swagger": {
    "NSwag": {
      "EnableJWTBearerAuth": true,
      "Doc": {
        "PostProcess": {
          "Info": {
            "Version": "v1",
            "Title": "Clinic Project API",
            "Description": "API for Clinic Management System",
            "Contact": {
              "Name": "5AETEAM-FPTU",
              "Email": "contact@clinic.com"
            },
            "License": {
              "Name": "MIT",
              "Url": "https://opensource.org/licenses/MIT"
            }
          }
        },
        "Auth": {
          "Bearer": {
            "Type": 1,
            "In": 1,
            "Scheme": "Bearer",
            "BearerFormat": "JWT",
            "Description": "Enter 'Bearer {token}'"
          }
        }
      }
    }
  }
}
